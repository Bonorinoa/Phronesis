# Phronesis environment variables
# Copy to .env locally and fill values. Do not commit .env.

# Modal
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Speech-to-text
DEEPGRAM_API_KEY=

# Retrieval / memory
PINECONE_API_KEY=
PINECONE_INDEX_NAME=phronesis

# Reasoning model
OLLAMA_API_KEY=
OLLAMA_MODEL=minimax-m3:cloud

# Observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=phronesis

# Optional / future
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
